# MongoDB configuration
MONGODB_URI=

# JWT / Session Secrets (32 characters required for session encryption)
SESSION_SECRET=s3cr3t_s3ss1on_s3cr3t_s3ss1on_s3cr3t_s3ss1on
JWT_SECRET=super_secret_jwt_key_for_backup_purposes

# Default Super Admin Seed Credentials
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Cloudinary configuration (placeholders)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Web Push VAPID keys (placeholders)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BPl9...your_public_key...
VAPID_PRIVATE_KEY=your_private_key